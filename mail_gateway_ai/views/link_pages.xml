<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="link_success" name="OdooPilot — Account Linked">
        <html>
            <head>
                <title>OdooPilot — Account Linked</title>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
            </head>
            <body class="bg-light">
                <div class="container mt-5 text-center">
                    <div class="card shadow-sm mx-auto" style="max-width:480px">
                        <div class="card-body p-5">
                            <div style="font-size:3em">✅</div>
                            <h3 class="mt-3">Account linked!</h3>
                            <p class="text-muted">
                                Your Odoo account (<strong><t t-esc="user.name"/></strong>) is now connected to Telegram.
                            </p>
                            <p class="text-muted small">You can close this tab and start chatting with your bot.</p>
                        </div>
                    </div>
                </div>
            </body>
        </html>
    </template>

    <template id="link_error" name="OdooPilot — Linking Error">
        <html>
            <head>
                <title>OdooPilot — Linking Error</title>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"/>
            </head>
            <body class="bg-light">
                <div class="container mt-5 text-center">
                    <div class="card shadow-sm mx-auto" style="max-width:480px">
                        <div class="card-body p-5">
                            <div style="font-size:3em">❌</div>
                            <h3 class="mt-3 text-danger">Linking failed</h3>
                            <p class="text-muted"><t t-esc="error"/></p>
                            <p class="text-muted small">Send <code>/link</code> to the bot again to get a fresh link.</p>
                        </div>
                    </div>
                </div>
            </body>
        </html>
    </template>
</odoo>
