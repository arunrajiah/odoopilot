<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view -->
    <record id="mail_gateway_ai_audit_view_list" model="ir.ui.view">
        <field name="name">mail.gateway.ai.audit.view.list</field>
        <field name="model">mail.gateway.ai.audit</field>
        <field name="arch" type="xml">
            <list string="OdooPilot Audit Log" create="false" delete="false">
                <field name="timestamp"/>
                <field name="user_id"/>
                <field name="channel"/>
                <field name="tool_name"/>
                <field name="success"/>
                <field name="error_message"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="mail_gateway_ai_audit_view_form" model="ir.ui.view">
        <field name="name">mail.gateway.ai.audit.view.form</field>
        <field name="model">mail.gateway.ai.audit</field>
        <field name="arch" type="xml">
            <form string="Audit Log Entry" create="false" delete="false">
                <sheet>
                    <group>
                        <group string="Event">
                            <field name="timestamp"/>
                            <field name="user_id"/>
                            <field name="channel"/>
                            <field name="tool_name"/>
                            <field name="success"/>
                        </group>
                        <group string="Details">
                            <field name="tool_args" widget="code"/>
                            <field name="result_summary"/>
                            <field name="error_message"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_mail_gateway_ai_audit" model="ir.actions.act_window">
        <field name="name">Audit Log</field>
        <field name="res_model">mail.gateway.ai.audit</field>
        <field name="view_mode">list,form</field>
    </record>

    <!-- Menu item -->
    <menuitem id="menu_mail_gateway_ai_audit"
              name="Audit Log"
              parent="mail_gateway_ai_identity_views.menu_mail_gateway_ai_root"
              action="action_mail_gateway_ai_audit"
              sequence="20"
              groups="base.group_system"/>
</odoo>
