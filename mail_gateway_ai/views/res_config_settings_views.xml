<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.mail.gateway.ai</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.action_general_configuration"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="AI Mail Gateway" string="AI Mail Gateway" data-key="mail_gateway_ai">
                    <h2>AI Mail Gateway</h2>
                    <div class="row mt16 o_settings_container">
                        <div class="col-xs-12 col-md-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <span class="o_form_label">Configuration</span>
                                <div class="text-muted">
                                    Configure the OdooPilot service URL and API credentials in your
                                    <code>.env</code> file on the OdooPilot host.
                                    See <a href="https://github.com/arunrajiah/odoopilot" target="_blank">
                                    github.com/arunrajiah/odoopilot</a> for setup instructions.
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </xpath>
        </field>
    </record>
</odoo>
