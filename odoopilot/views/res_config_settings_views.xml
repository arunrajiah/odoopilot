<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="res_config_settings_view_form" model="ir.ui.view">
        <field name="name">res.config.settings.view.form.odoopilot</field>
        <field name="model">res.config.settings</field>
        <field name="inherit_id" ref="base_setup.res_config_settings_view_form"/>
        <field name="arch" type="xml">
            <xpath expr="//div[hasclass('settings')]" position="inside">
                <div class="app_settings_block" data-string="OdooPilot" string="OdooPilot" data-key="odoopilot">
                    <h2>OdooPilot — AI Agent for Telegram &amp; WhatsApp</h2>

                    <div class="row mt16 o_settings_container">
                        <!-- Telegram -->
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="odoopilot_telegram_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="odoopilot_telegram_enabled" string="Enable Telegram"/>
                                <div class="text-muted">Activate the Telegram bot.</div>
                                <div class="content-group" invisible="not odoopilot_telegram_enabled">
                                    <div class="mt8">
                                        <field name="odoopilot_telegram_bot_token" string="Bot Token" widget="password" placeholder="123456789:ABCdef..."/>
                                    </div>
                                    <div class="mt4">
                                        <field name="odoopilot_telegram_webhook_secret" string="Webhook Secret" widget="password" placeholder="auto-generated when you register the webhook"/>
                                    </div>
                                    <div class="mt8">
                                        <button name="action_test_telegram_connection" type="object" string="Test connection" class="btn btn-secondary btn-sm"/>
                                        <button name="action_register_telegram_webhook" type="object" string="Register webhook" class="btn btn-primary btn-sm ms-2"/>
                                    </div>
                                    <div class="text-muted mt4">
                                        The webhook URL will be set to <code>YOUR_ODOO_URL/odoopilot/webhook/telegram</code>.
                                        A 32-byte secret token is auto-generated and registered with Telegram so the endpoint can verify every incoming request.
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- WhatsApp -->
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="odoopilot_whatsapp_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="odoopilot_whatsapp_enabled" string="Enable WhatsApp"/>
                                <div class="text-muted">Activate the WhatsApp Cloud API bot.</div>
                                <div class="content-group" invisible="not odoopilot_whatsapp_enabled">
                                    <div class="mt8">
                                        <field name="odoopilot_whatsapp_phone_number_id" string="Phone Number ID" placeholder="123456789012345"/>
                                    </div>
                                    <div class="mt4">
                                        <field name="odoopilot_whatsapp_access_token" string="Access Token" widget="password" placeholder="EAABxx..."/>
                                    </div>
                                    <div class="mt4">
                                        <field name="odoopilot_whatsapp_verify_token" string="Verify Token" widget="password" placeholder="any random string"/>
                                    </div>
                                    <div class="mt4">
                                        <field name="odoopilot_whatsapp_app_secret" string="App Secret (required for security)" widget="password" placeholder="from Meta App Dashboard -> Settings -> Basic"/>
                                    </div>
                                    <div class="mt8">
                                        <button name="action_test_whatsapp_connection" type="object" string="Test connection" class="btn btn-secondary btn-sm"/>
                                    </div>
                                    <div class="alert alert-warning mt4 p-2" role="alert" style="font-size:0.85em;">
                                        <strong>App Secret is required.</strong> Every webhook POST is verified with HMAC-SHA256 against the <code>X-Hub-Signature-256</code> header Meta sends. Without it, the webhook rejects all incoming traffic.
                                    </div>
                                    <div class="text-muted mt4">
                                        Set the webhook URL in Meta Developer console to <code>YOUR_ODOO_URL/odoopilot/webhook/whatsapp</code>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- LLM -->
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane"/>
                            <div class="o_setting_right_pane">
                                <label string="AI Provider"/>
                                <div class="text-muted">Choose which LLM powers the bot.</div>
                                <div class="mt8">
                                    <field name="odoopilot_llm_provider" string="Provider"/>
                                </div>
                                <div class="mt4">
                                    <field name="odoopilot_llm_api_key" string="API Key" widget="password" placeholder="sk-..."/>
                                </div>
                                <div class="mt4">
                                    <field name="odoopilot_llm_model" string="Model override" placeholder="leave blank for default"/>
                                </div>
                            </div>
                        </div>

                        <!-- Voice / Speech-to-Text -->
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="odoopilot_voice_enabled"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="odoopilot_voice_enabled" string="Voice messages"/>
                                <div class="text-muted">
                                    Transcribe Telegram and WhatsApp voice notes via Whisper, then run them through the agent like typed text.
                                </div>
                                <div class="content-group" invisible="not odoopilot_voice_enabled">
                                    <div class="mt8">
                                        <field name="odoopilot_stt_provider" string="STT Provider"/>
                                    </div>
                                    <div class="mt4">
                                        <field name="odoopilot_stt_api_key" string="STT API Key" widget="password" placeholder="gsk_... or sk-..."/>
                                    </div>
                                    <div class="mt4">
                                        <field name="odoopilot_stt_model" string="STT Model" placeholder="leave blank for default"/>
                                    </div>
                                    <div class="mt4">
                                        <field name="odoopilot_voice_max_duration_seconds" string="Max duration (s)"/>
                                    </div>
                                    <div class="text-muted mt4">
                                        Voice messages longer than the cap are rejected before download. Default: 60s. Bandwidth + STT cost protection.
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Notifications -->
                    <h2 class="mt16">Proactive Notifications</h2>
                    <div class="row mt16 o_settings_container" invisible="not odoopilot_telegram_enabled">
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="odoopilot_notify_task_digest"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="odoopilot_notify_task_digest" string="Daily task digest"/>
                                <div class="text-muted">
                                    Send each linked user their overdue and today's tasks every morning at 08:00 UTC.
                                </div>
                            </div>
                        </div>
                        <div class="col-12 col-lg-6 o_setting_box">
                            <div class="o_setting_left_pane">
                                <field name="odoopilot_notify_invoice_alerts"/>
                            </div>
                            <div class="o_setting_right_pane">
                                <label for="odoopilot_notify_invoice_alerts" string="Overdue invoice alerts"/>
                                <div class="text-muted">
                                    Send users with accounting access a daily overdue invoice summary at 09:00 UTC.
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="row mt8" invisible="not odoopilot_telegram_enabled">
                        <div class="col-12">
                            <div class="text-muted">
                                <i class="fa fa-info-circle"/> Notification times are in UTC. Cron schedules can be adjusted under <b>Settings → Technical → Scheduled Actions</b>.
                            </div>
                        </div>
                    </div>
                    <div class="row mt8" invisible="odoopilot_telegram_enabled">
                        <div class="col-12">
                            <div class="alert alert-info" role="alert">
                                Enable Telegram above to configure proactive notifications.
                            </div>
                        </div>
                    </div>
                    <!-- ── Author + community strip ── -->
                    <div class="row mt24">
                        <div class="col-12">
                            <div style="background:#f8f5ff; border:1px solid #e9d5ff; border-radius:8px; padding:16px 20px;">
                                <div style="font-size:0.92em; color:#374151; margin-bottom:10px;">
                                    <span style="font-size:1.2em; margin-right:6px;">🤖</span>
                                    <strong>OdooPilot</strong> is a free, open-source app developed and maintained by
                                    <a href="https://github.com/arunrajiah" target="_blank" rel="noopener noreferrer" style="color:#7c3aed; font-weight:600; text-decoration:none;">arunrajiah</a>.
                                    If it saves your team time, please consider supporting the project.
                                </div>

                                <!-- Action links: Sponsor / Feedback / Support / Security -->
                                <div style="display:flex; flex-wrap:wrap; gap:10px; margin-top:6px;">

                                    <a href="https://github.com/sponsors/arunrajiah" target="_blank" rel="noopener noreferrer"
                                       style="flex:1 1 200px; min-width:180px; background:#fff; border:1px solid #e9d5ff; border-radius:6px; padding:10px 14px; text-decoration:none; color:#374151; display:flex; align-items:center; gap:10px;">
                                        <span style="font-size:1.2em;">♥</span>
                                        <div>
                                            <div style="font-size:0.88em; font-weight:700; color:#7c3aed;">Sponsor on GitHub</div>
                                            <div style="font-size:0.78em; color:#6b7280;">Keep new features and Odoo version support coming</div>
                                        </div>
                                    </a>

                                    <a href="https://github.com/arunrajiah/odoopilot/discussions/new?category=ideas" target="_blank" rel="noopener noreferrer"
                                       style="flex:1 1 200px; min-width:180px; background:#fff; border:1px solid #e9d5ff; border-radius:6px; padding:10px 14px; text-decoration:none; color:#374151; display:flex; align-items:center; gap:10px;">
                                        <span style="font-size:1.2em;">💬</span>
                                        <div>
                                            <div style="font-size:0.88em; font-weight:700; color:#7c3aed;">Feedback &amp; ideas</div>
                                            <div style="font-size:0.78em; color:#6b7280;">Suggest features in GitHub Discussions</div>
                                        </div>
                                    </a>

                                    <a href="https://github.com/arunrajiah/odoopilot/issues/new/choose" target="_blank" rel="noopener noreferrer"
                                       style="flex:1 1 200px; min-width:180px; background:#fff; border:1px solid #e9d5ff; border-radius:6px; padding:10px 14px; text-decoration:none; color:#374151; display:flex; align-items:center; gap:10px;">
                                        <span style="font-size:1.2em;">🛠</span>
                                        <div>
                                            <div style="font-size:0.88em; font-weight:700; color:#7c3aed;">Report a bug</div>
                                            <div style="font-size:0.78em; color:#6b7280;">Open an issue on GitHub</div>
                                        </div>
                                    </a>

                                    <a href="https://github.com/arunrajiah/odoopilot/security/advisories/new" target="_blank" rel="noopener noreferrer"
                                       style="flex:1 1 200px; min-width:180px; background:#fff; border:1px solid #e9d5ff; border-radius:6px; padding:10px 14px; text-decoration:none; color:#374151; display:flex; align-items:center; gap:10px;">
                                        <span style="font-size:1.2em;">🔒</span>
                                        <div>
                                            <div style="font-size:0.88em; font-weight:700; color:#7c3aed;">Report a security issue</div>
                                            <div style="font-size:0.78em; color:#6b7280;">Private disclosure via GitHub Security</div>
                                        </div>
                                    </a>

                                </div>

                                <!-- Quick reference links -->
                                <div style="margin-top:12px; padding-top:10px; border-top:1px solid #e9d5ff; font-size:0.82em; color:#6b7280;">
                                    <a href="https://github.com/arunrajiah/odoopilot" target="_blank" rel="noopener noreferrer" style="color:#7c3aed; text-decoration:none; margin-right:14px;">📦 Source code</a>
                                    <a href="https://github.com/arunrajiah/odoopilot/blob/main/README.md" target="_blank" rel="noopener noreferrer" style="color:#7c3aed; text-decoration:none; margin-right:14px;">📖 Documentation</a>
                                    <a href="https://github.com/arunrajiah/odoopilot/blob/main/CHANGELOG.md" target="_blank" rel="noopener noreferrer" style="color:#7c3aed; text-decoration:none; margin-right:14px;">📜 Changelog</a>
                                    <a href="https://github.com/arunrajiah/odoopilot/blob/main/SECURITY.md" target="_blank" rel="noopener noreferrer" style="color:#7c3aed; text-decoration:none;">🛡 Security policy</a>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
            </xpath>
        </field>
    </record>
</odoo>
