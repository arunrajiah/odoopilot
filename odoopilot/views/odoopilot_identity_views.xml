<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- List view -->
    <record id="odoopilot_identity_view_list" model="ir.ui.view">
        <field name="name">odoopilot.identity.view.list</field>
        <field name="model">odoopilot.identity</field>
        <field name="arch" type="xml">
            <list string="OdooPilot Identities">
                <field name="user_id"/>
                <field name="channel"/>
                <field name="chat_id"/>
                <field name="display_name_channel"/>
                <field name="linked_at"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <!-- Form view -->
    <record id="odoopilot_identity_view_form" model="ir.ui.view">
        <field name="name">odoopilot.identity.view.form</field>
        <field name="model">odoopilot.identity</field>
        <field name="arch" type="xml">
            <form string="OdooPilot Identity">
                <sheet>
                    <group>
                        <group string="User">
                            <field name="user_id"/>
                            <field name="active"/>
                        </group>
                        <group string="Channel">
                            <field name="channel"/>
                            <field name="chat_id"/>
                            <field name="display_name_channel"/>
                            <field name="linked_at"/>
                        </group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_odoopilot_identity" model="ir.actions.act_window">
        <field name="name">OdooPilot Identities</field>
        <field name="res_model">odoopilot.identity</field>
        <field name="view_mode">list,form</field>
        <field name="context">{"active_test": False}</field>
    </record>

    <!-- Menu items -->
    <menuitem id="menu_odoopilot_root"
              name="OdooPilot"
              sequence="90"
              groups="base.group_system"/>

    <menuitem id="menu_odoopilot_identity"
              name="User Identities"
              parent="menu_odoopilot_root"
              action="action_odoopilot_identity"
              sequence="10"
              groups="base.group_system"/>
</odoo>
