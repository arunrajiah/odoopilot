<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="link_success" name="OdooPilot — Account Linked">
        <html>
            <head>
                <title>OdooPilot — Account Linked</title>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <style>
                    body { font-family: sans-serif; background: #f8f9fa; margin: 0; padding: 0; }
                    .container { max-width: 480px; margin: 80px auto; text-align: center; padding: 0 16px; }
                    .card { background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.1); padding: 40px 32px; }
                    .icon { font-size: 3em; }
                    h3 { margin: 16px 0 8px; }
                    p { color: #6c757d; margin: 8px 0; }
                    .small { font-size: .875em; }
                </style>
            </head>
            <body>
                <div class="container">
                    <div class="card">
                        <div class="icon">✅</div>
                        <h3>Account linked!</h3>
                        <p>
                            Your Odoo account (<strong><t t-esc="user.name"/></strong>) is now connected to Telegram.
                        </p>
                        <p class="small">You can close this tab and start chatting with your bot.</p>
                    </div>
                </div>
            </body>
        </html>
    </template>

    <template id="link_error" name="OdooPilot — Linking Error">
        <html>
            <head>
                <title>OdooPilot — Linking Error</title>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1"/>
                <style>
                    body { font-family: sans-serif; background: #f8f9fa; margin: 0; padding: 0; }
                    .container { max-width: 480px; margin: 80px auto; text-align: center; padding: 0 16px; }
                    .card { background: #fff; border-radius: 8px; box-shadow: 0 2px 8px rgba(0,0,0,.1); padding: 40px 32px; }
                    .icon { font-size: 3em; }
                    h3 { margin: 16px 0 8px; color: #dc3545; }
                    p { color: #6c757d; margin: 8px 0; }
                    .small { font-size: .875em; }
                    code { background: #e9ecef; padding: 2px 6px; border-radius: 4px; }
                </style>
            </head>
            <body>
                <div class="container">
                    <div class="card">
                        <div class="icon">❌</div>
                        <h3>Linking failed</h3>
                        <p><t t-esc="error"/></p>
                        <p class="small">Send <code>/link</code> to the bot again to get a fresh link.</p>
                    </div>
                </div>
            </body>
        </html>
    </template>
</odoo>
