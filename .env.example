# Odoo connection
ODOO_URL=https://odoo.example.com
ODOO_DB=mycompany
ODOO_ADMIN_USER=admin
ODOO_ADMIN_PASSWORD=admin

# Telegram
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrSTUvwxYZ
TELEGRAM_WEBHOOK_URL=https://odoopilot.example.com
# Optional: adds a secret header to webhook calls for extra security
# TELEGRAM_WEBHOOK_SECRET=your-random-secret

# LLM provider: openai | anthropic | ollama | groq
LLM_PROVIDER=anthropic

# OpenAI (if LLM_PROVIDER=openai)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=  # leave blank for api.openai.com

# Anthropic (if LLM_PROVIDER=anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Ollama (if LLM_PROVIDER=ollama)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.1

# Groq (if LLM_PROVIDER=groq)
# GROQ_API_KEY=gsk_...

# Storage (default: SQLite)
# DATABASE_URL=sqlite+aiosqlite:///./odoopilot.db
# On Fly.io (persistent volume mounted at /app/data):
# DATABASE_URL=sqlite+aiosqlite:////app/data/odoopilot.db
# For Postgres: postgresql+asyncpg://user:pass@host:5432/dbname

# App
# SECRET_KEY=change-me-in-production
# LOG_LEVEL=INFO
